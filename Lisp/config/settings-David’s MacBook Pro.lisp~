   ("SEP" "U" 9)
   ("OCT" "V" 10)
   ("NOV" "X" 11)
   ("DEC" "Z" 12)))

(defun make-oec-symbol (market tdate)
  (block nil
  (let ((month ;(subseq (third (assoc market *C-list*)) 0 3))
         (subseq  (contract-month market tdate) 0 3))
          year month-code mkt)
 
  ; (print month)
    (when (member market *forex-list*) (return (format nil "~A" (cdr (assoc market *oec-symbol*)))))
   
   (when (member market *stocks-list*)
         (setq mkt (format nil "~A" market))
         (return (subseq mkt 0 (position #\. mkt))))
   (setq month-code (second (assoc  month *month-codes* :Test 'equal)))
   (if (>= (third (assoc month *month-codes* :test 'equal))(nummonth tdate))
       (setq year (subseq (format nil "~A" (numyear tdate)) 3))
       (setq year (subseq (format nil "~A" (1+ (numyear tdate))) 3)))

   (string-append (format nil "~A" (cdr (assoc market *oec-symbol*))) month-code year))))





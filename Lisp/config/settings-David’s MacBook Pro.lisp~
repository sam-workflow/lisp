(defun add-limit (market lim)
 (let (cfg-in cfg-out (path "~/mk-data/index.cfg"))

  (with-open-file (str path :direction :input)
   (setq cfg-in (read str)))

   (dolist (ith cfg-in)
    (if (eql market (car ith))
        (push (nconc ith (list (cons 'LIMIT lim))) cfg-out)
        (push ith cfg-out)))

  (with-open-file (str path :direction :output :if-exists :supersede)
     (format str "(")
    (dolist (kth cfg-out)
       (format str "~S~%" kth))
     (format str ")")
    )
))

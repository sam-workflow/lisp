                          (string-append *upper-dir-warehouse* "daytradewarehouse3.backup"))
        )
 (dolist (ith markets)
  ; (populate-day-trades3 ith date (cdr (assoc ith *market-days-available*)))

   (setq path (string-append *upper-dir-warehouse* (format nil "~A" ith) "daytrades3.dat"))
